# ════════════════════════════════════════════════
# ImmortalWrt 自定义构建配置
# 目标平台: x86/64
# 包含: Passwall + OpenClash + 首次启动向导
# ════════════════════════════════════════════════

# ──── 目标平台 ────────────────────────────────
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# ──── 镜像格式（x86 通用）─────────────────────
CONFIG_TARGET_KERNEL_PARTSIZE=64
CONFIG_TARGET_ROOTFS_PARTSIZE=1024
CONFIG_GRUB_EFI_IMAGES=y
CONFIG_TARGET_IMAGES_GZIP=y

# ──── 基础系统 ────────────────────────────────
# 必须禁用标准 dnsmasq，使用 dnsmasq-full（Passwall 和 OpenClash 依赖）
CONFIG_PACKAGE_dnsmasq=n
CONFIG_PACKAGE_dnsmasq-full=y

# ──── 网络内核模块（代理流量转发必需）─────────
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-ipt-tproxy=y
CONFIG_PACKAGE_iptables-mod-tproxy=y
CONFIG_PACKAGE_ip6tables-mod-tproxy=y
CONFIG_PACKAGE_kmod-nf-conntrack-netlink=y

# ──── 工具 ────────────────────────────────────
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_iperf3=y

# ──── LuCI Web 界面 ───────────────────────────
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl-openssl=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-ipkg=y
CONFIG_PACKAGE_luci-lib-fs=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y

# ──── Passwall ────────────────────────────────
CONFIG_PACKAGE_luci-app-passwall=y
# 协议支持（按需启用）
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_ChinaDNS_NG=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_sing_box=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Hysteria=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Libev_Client=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_ShadowsocksR_Libev_Client=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_NaiveProxy=y
# 核心二进制包
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_sing-box=y
CONFIG_PACKAGE_chinadns-ng=y
CONFIG_PACKAGE_v2ray-geodata=y
CONFIG_PACKAGE_v2ray-geoview=y

# ──── OpenClash ───────────────────────────────
CONFIG_PACKAGE_luci-app-openclash=y
# OpenClash 依赖
CONFIG_PACKAGE_ruby=y
CONFIG_PACKAGE_ruby-yaml=y
CONFIG_PACKAGE_ruby-psych=y

# ──── SSL / TLS ───────────────────────────────
CONFIG_PACKAGE_libopenssl=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_ca-bundle=y

# ──── IPv6 支持 ───────────────────────────────
CONFIG_PACKAGE_ip6tables=y
CONFIG_PACKAGE_kmod-ip6tables=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
